# 使用官方 Go 镜像作为构建阶段
FROM golang:1.24.2-alpine AS builder

# 安装必要的构建工具
RUN apk add --no-cache git make

# 设置工作目录
WORKDIR /workspace

# 克隆源码
RUN git clone https://github.com/jedisct1/openapi-mcp.git .

# 构建二进制文件
RUN make

# 创建最终运行镜像
FROM alpine:3.22

# 安装必要的运行时依赖
RUN apk add --no-cache ca-certificates curl

# 设置工作目录
WORKDIR /app

# 从构建阶段复制二进制文件
COPY --from=builder /workspace/bin/ ./

# 暴露 HTTP 端口（当使用 --http 参数时）
EXPOSE 8080
