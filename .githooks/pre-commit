#!/bin/sh

# ANSI color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "Running pre-commit hook..."

# Check for goimports
if command -v goimports >/dev/null 2>&1; then
    FORMAT_CMD="goimports -w"
    TOOL_NAME="goimports"
elif [ -f "$HOME/go/bin/goimports" ]; then
    FORMAT_CMD="$HOME/go/bin/goimports -w"
    TOOL_NAME="goimports (from $HOME/go/bin)"
elif [ -f "$GOPATH/bin/goimports" ]; then
    FORMAT_CMD="$GOPATH/bin/goimports -w"
    TOOL_NAME="goimports (from $GOPATH/bin)"
else
    FORMAT_CMD="gofmt -w -s"
    TOOL_NAME="gofmt"
fi

echo "Using ${GREEN}${TOOL_NAME}${NC} for formatting."

# Get list of staged go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.go$")

if [ -z "$STAGED_GO_FILES" ]; then
    # echo "No Go files staged."
    exit 0
fi

# Format each file and re-add to index
for FILE in $STAGED_GO_FILES; do
    # Check if file exists (in case it was deleted but still in diff)
    if [ -f "$FILE" ]; then
        echo "Formatting $FILE..."
        $FORMAT_CMD "$FILE"
        git add "$FILE"
    fi
done

echo "${GREEN}Pre-commit formatting complete.${NC}"
exit 0
