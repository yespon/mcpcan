# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
vendor/

# bin
bin/*
!bin/protoc*

# data
data/*

# logs
logs/*

# protobuf
api/**/*.go
api/**/*.json
api/openapi.yaml

# config
config/*
!config/.empty
config-*
!config-example

# cmd
cmd/**/__debug_*
cmd/**/data/
cmd/**/init-data/
cmd/**/logs/

# test
.env
test/go-test/config.json

.idea
.DS_Store
.vscode
__debug_bin*

# Air hot-reload build output
tmp/

# Air config (managed by docker-compose mounts)
.air.toml

