{
  "run": {
    "timeout": "5m",
    "modules-download-mode": "readonly"
  },
  "linters-settings": {
    "gofmt": {
      "simplify": true
    },
    "goimports": {
      "local-prefixes": "github.com/kymo-mcp/mcpcan"
    }
  },
  "linters": {
    "disable-all": true,
    "enable": [
      "errcheck",
      "gosimple",
      "govet",
      "ineffassign",
      "staticcheck",
      "typecheck",
      "unused",
      "gofmt",
      "goimports"
    ]
  },
  "issues": {
    "exclude-use-default": false,
    "max-issues-per-linter": 0,
    "max-same-issues": 0
  }
}
